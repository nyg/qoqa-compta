# ──────────────────────────────────────────────────────────────────────────────
# crawler/.env.example — copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon.tech recommended)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/qoqa?sslmode=require

# Path to your Chrome user-data directory
# macOS: ~/Library/Application Support/Google/Chrome
# Linux: ~/.config/google-chrome
CHROME_USER_DATA_DIR=/home/you/.config/google-chrome

# Directory where PDFs will be downloaded (relative to this file or absolute)
PDF_DOWNLOAD_DIR=./pdfs
