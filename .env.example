# ──────────────────────────────────────────────────────────────────────────────
# Root .env.example — copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon.tech recommended)
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/qoqa?sslmode=require

# Path to your Chrome user-data directory (used by the crawler to reuse your session)
# macOS default: ~/Library/Application Support/Google/Chrome
# Linux default:  ~/.config/google-chrome
CHROME_USER_DATA_DIR=/home/you/.config/google-chrome

# Directory where downloaded PDFs will be stored (relative or absolute)
PDF_DOWNLOAD_DIR=./crawler/pdfs
